# Face Recognition Attendance System - Environment Configuration
# Copy this file to .env and update with your settings

# ============================================================
# SERVER CONFIGURATION
# ============================================================
HOST=0.0.0.0
PORT=8000

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# Supabase PostgreSQL connection string
# Find in: Supabase Dashboard → Project Settings → Database → URI
DATABASE_URL=postgresql://postgres:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ============================================================
# SUPABASE API KEYS
# ============================================================
# Find in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# ============================================================
# SECURITY SETTINGS
# ============================================================
# IMPORTANT: Change this to a random secret key in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================
# FACE RECOGNITION SETTINGS
# ============================================================
# Face detection confidence (0.0 to 1.0)
# Lower = more faces detected, Higher = more accurate
FACE_DETECTION_CONFIDENCE=0.5

# Face recognition threshold (0.0 to 1.0)
# Lower = stricter matching, Higher = more lenient
FACE_RECOGNITION_THRESHOLD=0.4

# Anti-spoofing threshold (0.0 to 1.0)
# Higher = stricter anti-spoofing
ANTI_SPOOFING_THRESHOLD=0.60

# ============================================================
# ATTENDANCE SETTINGS
# ============================================================
# Attendance window (24-hour format HH:MM)
ATTENDANCE_WINDOW_START=09:00
ATTENDANCE_WINDOW_END=17:00

# Allow multiple attendance marks per day
ALLOW_MULTIPLE_ATTENDANCE=false

# ============================================================
# FILE PATHS
# ============================================================
# Paths for storing data (relative to project root)
STUDENT_IMAGES_PATH=./data/student_images
EMBEDDINGS_PATH=./data/embeddings
LOG_PATH=./logs

# ============================================================
# CAMERA SETTINGS
# ============================================================
# Camera index (0 = default camera, 1 = second camera, etc.)
CAMERA_INDEX=0

# Camera resolution (optional)
CAMERA_WIDTH=640
CAMERA_HEIGHT=480

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================
# CORS SETTINGS (for production)
# ============================================================
# Comma-separated list of allowed origins
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# For development, allow all origins (default)
# ALLOWED_ORIGINS=*
